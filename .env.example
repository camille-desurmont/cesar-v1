# CESAR – copy to .env and set paths after training
# Model and contract paths (used by API and CLI)
CESAR_MODEL_PATH=artifact_storage/model_latest.joblib
CESAR_CONTRACT_PATH=artifact_storage/contract_latest.json

# API base URL (used by acceptance tests and UI when calling the API)
CESAR_API_URL=http://localhost:8000

# Anthropic API key (used by the query command)
ANTHROPIC_API_KEY=your-api-key-here

# Path to data CSV (default: data/dvf_75115_000CM.csv)
CESAR_DATA_CSV=data/dvf_75115_000CM.csv